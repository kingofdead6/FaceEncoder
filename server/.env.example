# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Camera / capture ────────────────────────────────────
CAMERA_INDEX=0
FRAME_WIDTH=1280
FRAME_HEIGHT=720
PROCESS_WIDTH=960
TARGET_FPS=30
JPEG_QUALITY=80
MIRROR_DEFAULT=true

# ── Detection ───────────────────────────────────────────
MODELS_DIR=models             # MediaPipe model cache (auto-downloaded on first run)
FACE_MIN_CONFIDENCE=0.5
HAND_MAX_NUM=2
HAND_MIN_PRESENCE_CONFIDENCE=0.5
HAND_MIN_DETECTION_CONFIDENCE=0.5
HAND_MIN_TRACKING_CONFIDENCE=0.5

# ── Mask shaping / smoothing ────────────────────────────
MASK_FEATHER_PX=41
FACE_PAD_X=0.28
FACE_PAD_Y=0.42
HAND_PAD=0.25
SINGLE_HAND_EXPAND=0.55
SMOOTH_ALPHA=0.45
SMOOTH_HOLD_FRAMES=8
